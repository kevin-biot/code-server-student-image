# Required environment variables for deployment
# Copy to .env and fill in values before running deploy scripts
#
# Usage: source .env && ./admin/deploy/complete-student-setup-simple.sh 1 25

# Password for code-server web access and OpenShift console (students use this to log in)
SHARED_PASSWORD=
STUDENT_PASSWORD=
CONSOLE_PASSWORD=

# Pulumi passphrase (only needed for devops-bootcamp profile)
PULUMI_CONFIG_PASSPHRASE=

# OpenShift cluster apps domain (e.g., apps.mycluster.example.com)
CLUSTER_DOMAIN=

# ArgoCD server URL (only needed for GitOps profiles)
# Typically: openshift-gitops-server-openshift-gitops.${CLUSTER_DOMAIN}
ARGOCD_SERVER_URL=
